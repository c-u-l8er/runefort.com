                G+'в”Ӯ  '+R+'в”Ӯ  '+T+' 8 tiles  '+D+'в”Ӯ  types: goal                  в”Ӯ  conf: '+G+'0.78  '+R+'в”Ӯ'+G+'  в”Ӯ',
                G+'в”Ӯ  '+R+'в”Ӯ  '+T+'activity: '+A+'в–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв–‘в–‘в–‘в–‘в–‘ 0.65'+T+'  state: '+G+'active     '+R+'в”Ӯ'+G+'  в”Ӯ',
