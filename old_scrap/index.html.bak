<!doctype html>
<html lang="en">
    <head>
        <meta charset="UTF-8" />
        <meta name="viewport" content="width=device-width, initial-scale=1.0" />
        <title>RuneFort вҖ” Spatial cognition for autonomous workflows</title>
        <meta
            name="description"
            content="Dark factories run with the lights off. RuneFort turns them back on вҖ” not with dashboards, but with a place you can walk through. Spatial visualization for AI operating systems, agent workflows, and continual learning loops."
        />
        <meta
            name="keywords"
            content="spatial visualization, AI observability, dark factory, autonomous agents, PULSE loops, cognitive architecture, agent workflows, continual learning"
        />
        <link rel="preconnect" href="https://fonts.googleapis.com" />
        <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
        <link
            href="https://fonts.googleapis.com/css2?family=Cinzel:wght@400;500;600;700&family=IBM+Plex+Sans:wght@300;400;500;600&family=JetBrains+Mono:wght@400;500;600&display=swap"
            rel="stylesheet"
        />
        <!-- Prism.js syntax highlighting -->
        <link
            href="https://cdnjs.cloudflare.com/ajax/libs/prism/1.29.0/themes/prism-tomorrow.min.css"
            rel="stylesheet"
        />
        <!-- rot.js вҖ” ROguelike Toolkit for blueprint rendering -->
        <style>
            :root {
                --bg: #09090d;
                --surface: #0e0f14;
                --surface-2: #15161d;
                --surface-3: #1c1d26;
                --border: rgba(255, 255, 255, 0.06);
                --border-2: rgba(255, 255, 255, 0.1);
                --text: #e4e2dc;
                --dim: #7a7770;
                --muted: #44423d;
                --amber: #e8a84c;
                --amber-dim: rgba(232, 168, 76, 0.12);
                --amber-glow: rgba(232, 168, 76, 0.06);
                --stone: #8a9a9e;
                --stone-dim: rgba(138, 154, 158, 0.12);
                --rune: #c4956a;
                --rune-dim: rgba(196, 149, 106, 0.15);
                --seal: #5b6a8a;
                --alert: #e85a5a;
                --serif: "Cinzel", serif;
                --sans: "IBM Plex Sans", sans-serif;
                --mono: "JetBrains Mono", monospace;
                --max-w: 1100px;
                --gutter: clamp(1.5rem, 4vw, 3rem);
            }

            *,
            *::before,
            *::after {
                box-sizing: border-box;
                margin: 0;
                padding: 0;
            }

            html {
                scroll-behavior: smooth;
                -webkit-font-smoothing: antialiased;
            }

            body {
                background: var(--bg);
                color: var(--text);
                font-family: var(--sans);
                font-size: 17px;
                line-height: 1.7;
                overflow-x: hidden;
            }

            /* Tile grid background */
            body::before {
                content: "";
                position: fixed;
                inset: 0;
                background-image:
                    linear-gradient(rgba(232, 168, 76, 0.025) 1px, transparent 1px),
                    linear-gradient(90deg, rgba(232, 168, 76, 0.025) 1px, transparent 1px);
                background-size: 48px 48px;
                pointer-events: none;
                z-index: 0;
            }

            /* Grain overlay */
            body::after {
                content: "";
                position: fixed;
                inset: 0;
                background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 256 256' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='noise'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.9' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23noise)' opacity='0.025'/%3E%3C/svg%3E");
                pointer-events: none;
                z-index: 9999;
            }

            ::selection {
                background: var(--amber);
                color: var(--bg);
            }

            a {
                color: var(--amber);
                text-decoration: none;
                transition: color 0.2s;
            }
            a:hover {
                color: var(--text);
            }

            .container {
                max-width: var(--max-w);
                margin: 0 auto;
                padding: 0 var(--gutter);
            }

            section {
                padding: 5rem 0;
                position: relative;
                z-index: 1;
            }

            /* Ambient glows */
            .glow {
                position: fixed;
                border-radius: 50%;
                pointer-events: none;
                z-index: 0;
                filter: blur(120px);
            }
            .glow-1 {
                width: 600px;
                height: 600px;
                background: var(--amber-glow);
                top: -5%;
                left: 55%;
                animation: drift 28s ease-in-out infinite alternate;
            }
            .glow-2 {
                width: 500px;
                height: 500px;
                background: var(--stone-dim);
                bottom: 10%;
                right: 60%;
                opacity: 0.4;
                animation: drift 34s ease-in-out infinite alternate-reverse;
            }
            @keyframes drift {
                0% { transform: translate(0, 0); }
                100% { transform: translate(50px, -40px); }
            }

            /* в”Җв”Җв”Җ NAV в”Җв”Җв”Җ */
            nav {
                position: fixed;
                top: 0;
                left: 0;
                right: 0;
                z-index: 100;
                background: rgba(9, 9, 13, 0.88);
                backdrop-filter: blur(12px);
                border-bottom: 1px solid var(--border);
                padding: 0.75rem 0;
            }
            .nav-inner {
                max-width: var(--max-w);
                margin: 0 auto;
                padding: 0 var(--gutter);
                display: flex;
                align-items: center;
                justify-content: space-between;
            }
            .nav-brand {
                font-family: var(--serif);
                font-size: 0.9rem;
                font-weight: 600;
                color: var(--text);
                letter-spacing: 0.12em;
                text-transform: uppercase;
            }
            .nav-brand .rune {
                color: var(--amber);
                margin-right: 0.3rem;
                font-size: 1rem;
            }
            .nav-links {
                display: flex;
                gap: 1.5rem;
                list-style: none;
            }
            .nav-links a {
                font-family: var(--mono);
                font-size: 0.7rem;
                letter-spacing: 0.08em;
                text-transform: uppercase;
                color: var(--dim);
                transition: color 0.2s;
            }
            .nav-links a:hover {
                color: var(--amber);
            }
            @media (max-width: 600px) {
                .nav-links { gap: 0.75rem; }
                .nav-links a { font-size: 0.6rem; }
            }

            /* в”Җв”Җв”Җ HERO в”Җв”Җв”Җ */
            .hero {
                padding-top: 11rem;
                padding-bottom: 5rem;
                text-align: center;
                position: relative;
                z-index: 1;
            }
            .hero-badge {
                font-family: var(--mono);
                font-size: 0.65rem;
                letter-spacing: 0.08em;
                color: var(--dim);
                padding: 0.4rem 1rem;
                border: 1px solid var(--border);
                border-radius: 100px;
                display: inline-block;
                margin-bottom: 2rem;
            }
            .hero h1 {
                font-family: var(--serif);
                font-weight: 400;
                font-size: clamp(2.4rem, 5.5vw, 4rem);
                line-height: 1.15;
                letter-spacing: 0.02em;
                margin-bottom: 1.5rem;
            }
            .hero h1 em {
                font-style: normal;
                color: var(--amber);
            }
            .hero .subline {
                font-size: 1.15rem;
                color: var(--dim);
                max-width: 620px;
                margin: 0 auto 2.5rem;
                line-height: 1.8;
            }
            .hero .cta-row {
                display: flex;
                gap: 0.75rem;
                justify-content: center;
                flex-wrap: wrap;
                margin-bottom: 1.5rem;
            }
            .hero .rune-sequence {
                font-size: 1.6rem;
                color: var(--rune);
                letter-spacing: 0.4em;
                margin-top: 2.5rem;
                opacity: 0.5;
                font-weight: 300;
            }

            /* Buttons */
            .btn {
                font-family: var(--mono);
                font-size: 0.72rem;
                font-weight: 500;
                letter-spacing: 0.06em;
                text-transform: uppercase;
                padding: 0.85rem 1.75rem;
                border: none;
                cursor: pointer;
                transition: all 0.3s ease;
                text-decoration: none;
                display: inline-block;
            }
            .btn-primary {
                background: var(--amber);
                color: var(--bg);
            }
            .btn-primary:hover {
                color: var(--bg);
                box-shadow: 0 4px 24px rgba(232, 168, 76, 0.35);
                transform: translateY(-2px);
            }
            .btn-secondary {
                background: transparent;
                color: var(--amber);
                border: 1px solid rgba(232, 168, 76, 0.3);
            }
            .btn-secondary:hover {
                color: var(--text);
                border-color: rgba(232, 168, 76, 0.6);
                transform: translateY(-2px);
            }
            .btn-ghost {
                background: transparent;
                color: var(--dim);
                border: 1px solid var(--border);
            }
            .btn-ghost:hover {
                color: var(--text);
                border-color: var(--border-2);
                transform: translateY(-2px);
            }

            /* Section common */
            .section-label {
                font-family: var(--mono);
                font-size: 0.65rem;
                letter-spacing: 0.1em;
                text-transform: uppercase;
                color: var(--amber);
                margin-bottom: 2rem;
                display: inline-block;
                padding: 0.35rem 0.9rem;
                border: 1px solid rgba(232, 168, 76, 0.2);
                border-radius: 100px;
                background: var(--amber-glow);
            }
            section h2 {
                font-family: var(--serif);
                font-weight: 400;
                font-size: clamp(1.8rem, 3.5vw, 2.6rem);
                line-height: 1.2;
                margin-bottom: 1.5rem;
                letter-spacing: 0.01em;
            }
            section h2 em {
                font-style: italic;
                color: var(--amber);
            }
            .lead {
                font-size: 1.05rem;
                color: var(--dim);
                max-width: 700px;
                margin-bottom: 3rem;
                line-height: 1.8;
            }

            /* в”Җв”Җв”Җ FORT DIAGRAM в”Җв”Җв”Җ */
            .fort-diagram {
                background: var(--surface);
                border: 1px solid var(--border);
                border-radius: 10px;
                padding: 2rem;
                margin: 3rem 0;
                font-family: var(--mono);
                font-size: 0.72rem;
                line-height: 1.9;
                color: var(--dim);
                overflow-x: auto;
                white-space: pre;
                position: relative;
            }
            .fort-diagram::before {
                content: "";
                position: absolute;
                top: 0;
                left: 0;
                right: 0;
                height: 2px;
                background: linear-gradient(90deg, var(--amber), var(--rune), var(--stone));
            }
            .fort-diagram .room { color: var(--amber); }
            .fort-diagram .rune { color: var(--rune); opacity: 0.7; }
            .fort-diagram .wall { color: var(--muted); }
            .fort-diagram .flow { color: var(--stone); }
            .fort-diagram .label { color: var(--text); }

            /* в”Җв”Җв”Җ ZOOM LEVELS в”Җв”Җв”Җ */
            .zoom-grid {
                display: grid;
                grid-template-columns: repeat(5, 1fr);
                gap: 1rem;
                margin: 2.5rem 0;
            }
            @media (max-width: 900px) {
                .zoom-grid { grid-template-columns: repeat(3, 1fr); }
            }
            @media (max-width: 550px) {
                .zoom-grid { grid-template-columns: 1fr; }
            }
            .zoom-card {
                background: var(--surface);
                border: 1px solid var(--border);
                border-radius: 8px;
                padding: 1.5rem 1.25rem;
                transition: all 0.3s ease;
                position: relative;
                overflow: hidden;
                cursor: pointer;
                user-select: none;
            }
            .zoom-card:hover {
                border-color: var(--border-2);
                transform: translateY(-3px);
            }
            .zoom-card::before {
                content: "";
                position: absolute;
                top: 0;
                left: 0;
                right: 0;
                height: 2px;
                background: var(--amber);
                opacity: 0.3;
                transition: opacity 0.3s;
            }
            .zoom-card.active {
                border-color: rgba(232, 168, 76, 0.4);
                background: var(--surface-2);
            }
            .zoom-card.active::before {
                opacity: 1;
            }
            .zoom-level {
                font-family: var(--mono);
                font-size: 0.65rem;
                font-weight: 600;
                letter-spacing: 0.06em;
                color: var(--amber);
                margin-bottom: 0.5rem;
                transition: color 0.2s;
            }
            .zoom-card.active .zoom-level { color: var(--amber); }
            .zoom-name {
                font-family: var(--serif);
                font-size: 1.1rem;
                font-weight: 500;
                margin-bottom: 0.5rem;
                color: var(--text);
            }
            .zoom-desc {
                font-size: 0.82rem;
                color: var(--dim);
                line-height: 1.6;
            }

            /* в”Җв”Җв”Җ ZOOM VIEWER (xterm + code panel) в”Җв”Җв”Җ */
            .zoom-viewer {
                position: relative;
                margin: 2rem 0 0;
                border-radius: 10px;
                overflow: hidden;
                border: 1px solid var(--border);
            }
            .zoom-viewer-header {
                display: flex;
                align-items: center;
                justify-content: space-between;
                padding: 0.6rem 1.25rem;
                background: var(--surface-2);
                border-bottom: 1px solid var(--border);
            }
            .zoom-viewer-title {
                font-family: var(--mono);
                font-size: 0.65rem;
                font-weight: 600;
                letter-spacing: 0.08em;
                text-transform: uppercase;
                color: var(--amber);
            }
            .zoom-viewer-lang {
                font-family: var(--mono);
                font-size: 0.6rem;
                letter-spacing: 0.06em;
                color: var(--muted);
            }
            .zoom-viewer-body {
                position: relative;
            }
            #rot-container {
                background: var(--surface);
                display: flex;
                justify-content: center;
                padding: 1rem 0;
                overflow-x: auto;
            }
            #rot-container canvas {
                image-rendering: pixelated;
            }

            /* Code data section (hidden, holds JSON for Prism panels below) */
            .zoom-data-panel {
                position: relative;
                margin: 1.25rem 0 0;
                border-radius: 10px;
                overflow: hidden;
                border: 1px solid var(--border);
            }
            .zoom-data-panel .zoom-code {
                display: none;
                margin: 0;
            }
            .zoom-data-panel .zoom-code.active {
                display: block;
            }
            .zoom-data-header {
                display: flex;
                align-items: center;
                justify-content: space-between;
                padding: 0.6rem 1.25rem;
                background: var(--surface-2);
                border-bottom: 1px solid var(--border);
            }
            .zoom-data-title {
                font-family: var(--mono);
                font-size: 0.65rem;
                font-weight: 600;
                letter-spacing: 0.08em;
                text-transform: uppercase;
                color: var(--dim);
            }
            .zoom-data-lang {
                font-family: var(--mono);
                font-size: 0.6rem;
                letter-spacing: 0.06em;
                color: var(--muted);
            }

            /* в”Җв”Җв”Җ PRISM OVERRIDES в”Җв”Җв”Җ */
            pre[class*="language-"] {
                background: var(--surface) !important;
                margin: 0 !important;
                padding: 1.5rem 1.25rem !important;
                border-radius: 0 !important;
                font-family: var(--mono) !important;
                font-size: 0.78rem !important;
                line-height: 1.8 !important;
                border: none !important;
                overflow-x: auto;
            }
            code[class*="language-"] {
                font-family: var(--mono) !important;
                font-size: 0.78rem !important;
                text-shadow: none !important;
            }
            .token.comment,
            .token.block-comment,
            .token.prolog,
            .token.doctype,
            .token.cdata { color: var(--muted) !important; }
            .token.property,
            .token.tag,
            .token.boolean,
            .token.number,
            .token.constant,
            .token.symbol { color: var(--amber) !important; }
            .token.string,
            .token.char,
            .token.attr-value,
            .token.builtin { color: var(--stone) !important; }
            .token.selector,
            .token.attr-name,
            .token.atrule,
            .token.keyword { color: var(--rune) !important; }
            .token.punctuation { color: var(--dim) !important; }
            .token.operator,
            .token.entity,
            .token.url { color: var(--dim) !important; }
            .token.function { color: var(--text) !important; }
            ::selection { background: var(--amber) !important; color: var(--bg) !important; }

            /* в”Җв”Җв”Җ THREE PILLARS в”Җв”Җв”Җ */
            .pillar-grid {
                display: grid;
                grid-template-columns: repeat(3, 1fr);
                gap: 1.25rem;
                margin: 2.5rem 0;
            }
            @media (max-width: 750px) {
                .pillar-grid { grid-template-columns: 1fr; }
            }
            .pillar {
                background: var(--surface);
                border: 1px solid var(--border);
                border-radius: 10px;
                padding: 2rem 1.75rem;
                transition: all 0.3s ease;
                position: relative;
                overflow: hidden;
            }
            .pillar:hover {
                border-color: var(--border-2);
                transform: translateY(-3px);
            }
            .pillar::before {
                content: "";
                position: absolute;
                top: 0;
                left: 0;
                width: 3px;
                height: 100%;
            }
            .pillar:nth-child(1)::before { background: var(--amber); }
            .pillar:nth-child(2)::before { background: var(--stone); }
            .pillar:nth-child(3)::before { background: var(--rune); }
            .pillar-icon {
                font-size: 1.6rem;
                margin-bottom: 1rem;
            }
            .pillar h3 {
                font-family: var(--serif);
                font-size: 1.15rem;
                font-weight: 500;
                margin-bottom: 0.75rem;
            }
            .pillar:nth-child(1) h3 { color: var(--amber); }
            .pillar:nth-child(2) h3 { color: var(--stone); }
            .pillar:nth-child(3) h3 { color: var(--rune); }
            .pillar p {
                font-size: 0.88rem;
                color: var(--dim);
                line-height: 1.7;
            }

            /* в”Җв”Җв”Җ DARK FACTORY в”Җв”Җв”Җ */
            .dark-factory-split {
                display: grid;
                grid-template-columns: 1fr 1fr;
                gap: 2rem;
                margin: 2.5rem 0;
                align-items: start;
            }
            @media (max-width: 750px) {
                .dark-factory-split { grid-template-columns: 1fr; }
            }
            .df-card {
                background: var(--surface);
                border: 1px solid var(--border);
                border-radius: 10px;
                padding: 2rem;
                position: relative;
                overflow: hidden;
            }
            .df-card::before {
                content: "";
                position: absolute;
                top: 0;
                left: 0;
                right: 0;
                height: 2px;
            }
            .df-card.dark::before { background: var(--muted); }
            .df-card.lit::before { background: var(--amber); }
            .df-card h3 {
                font-family: var(--mono);
                font-size: 0.75rem;
                font-weight: 600;
                letter-spacing: 0.06em;
                text-transform: uppercase;
                margin-bottom: 1.25rem;
            }
            .df-card.dark h3 { color: var(--muted); }
            .df-card.lit h3 { color: var(--amber); }
            .df-card ul {
                list-style: none;
                padding: 0;
            }
            .df-card li {
                font-size: 0.88rem;
                color: var(--dim);
                padding: 0.4rem 0;
                border-bottom: 1px solid var(--border);
                line-height: 1.6;
            }
            .df-card li:last-child { border-bottom: none; }
            .df-card li .rune-glyph {
                color: var(--rune);
                margin-right: 0.5rem;
                font-size: 0.95rem;
            }

            /* в”Җв”Җв”Җ OVERLAYS в”Җв”Җв”Җ */
            .overlay-grid {
                display: grid;
                grid-template-columns: repeat(4, 1fr);
                gap: 1rem;
                margin: 2.5rem 0;
            }
            @media (max-width: 900px) {
                .overlay-grid { grid-template-columns: repeat(2, 1fr); }
            }
            @media (max-width: 500px) {
                .overlay-grid { grid-template-columns: 1fr; }
            }
            .overlay-card {
                background: var(--surface);
                border: 1px solid var(--border);
                border-radius: 8px;
                padding: 1.25rem;
                transition: all 0.3s ease;
            }
            .overlay-card:hover {
                border-color: var(--border-2);
            }
            .overlay-key {
                font-family: var(--mono);
                font-size: 0.7rem;
                font-weight: 600;
                width: 1.8rem;
                height: 1.8rem;
                border: 1px solid var(--amber-dim);
                border-radius: 4px;
                display: flex;
                align-items: center;
                justify-content: center;
                color: var(--amber);
                margin-bottom: 0.75rem;
                background: var(--amber-glow);
            }
            .overlay-name {
                font-family: var(--serif);
                font-size: 0.95rem;
                font-weight: 500;
                margin-bottom: 0.35rem;
                color: var(--text);
            }
            .overlay-desc {
                font-size: 0.78rem;
                color: var(--dim);
                line-height: 1.5;
            }

            /* в”Җв”Җв”Җ COMPONENT TABLE в”Җв”Җв”Җ */
            .component-table {
                width: 100%;
                border-collapse: collapse;
                margin: 2.5rem 0;
                font-size: 0.85rem;
            }
            .component-table th {
                font-family: var(--mono);
                font-size: 0.65rem;
                font-weight: 600;
                letter-spacing: 0.08em;
                text-transform: uppercase;
                color: var(--dim);
                text-align: left;
                padding: 0.75rem 1rem;
                border-bottom: 1px solid var(--border-2);
            }
            .component-table td {
                padding: 0.75rem 1rem;
                border-bottom: 1px solid var(--border);
                vertical-align: top;
            }
            .component-table tr:hover td {
                background: var(--surface);
            }
            .component-table .comp-name {
                font-family: var(--mono);
                color: var(--amber);
                font-size: 0.8rem;
                white-space: nowrap;
            }
            .component-table .comp-role {
                color: var(--text);
            }
            .component-table .comp-rule {
                color: var(--dim);
                font-size: 0.8rem;
            }

            /* в”Җв”Җв”Җ ECOSYSTEM в”Җв”Җв”Җ */
            .eco-grid {
                display: grid;
                grid-template-columns: repeat(3, 1fr);
                gap: 1rem;
                margin: 2.5rem 0;
            }
            @media (max-width: 750px) {
                .eco-grid { grid-template-columns: repeat(2, 1fr); }
            }
            @media (max-width: 500px) {
                .eco-grid { grid-template-columns: 1fr; }
            }
            .eco-card {
                background: var(--surface);
                border: 1px solid var(--border);
                border-radius: 8px;
                padding: 1.25rem;
                transition: all 0.3s ease;
            }
            .eco-card:hover {
                border-color: var(--border-2);
                transform: translateY(-2px);
            }
            .eco-rune {
                color: var(--rune);
                font-size: 1.1rem;
                margin-bottom: 0.5rem;
                display: block;
            }
            .eco-name {
                font-family: var(--serif);
                font-size: 0.95rem;
                font-weight: 500;
                margin-bottom: 0.25rem;
                color: var(--text);
            }
            .eco-role {
                font-size: 0.78rem;
                color: var(--dim);
            }

            /* в”Җв”Җв”Җ MATURITY LEVELS в”Җв”Җв”Җ */
            .maturity-strip {
                display: flex;
                gap: 0;
                margin: 2.5rem 0;
                border: 1px solid var(--border);
                border-radius: 8px;
                overflow: hidden;
            }
            @media (max-width: 750px) {
                .maturity-strip { flex-direction: column; }
            }
            .maturity-level {
                flex: 1;
                padding: 1.25rem 1rem;
                border-right: 1px solid var(--border);
                background: var(--surface);
                transition: background 0.2s;
            }
            .maturity-level:last-child { border-right: none; }
            .maturity-level:hover { background: var(--surface-2); }
            .maturity-level.active {
                background: var(--surface-2);
                border-bottom: 2px solid var(--amber);
            }
            .maturity-num {
                font-family: var(--mono);
                font-size: 0.65rem;
                color: var(--muted);
                margin-bottom: 0.25rem;
            }
            .maturity-level.active .maturity-num { color: var(--amber); }
            .maturity-title {
                font-family: var(--serif);
                font-size: 0.85rem;
                font-weight: 500;
                color: var(--dim);
                margin-bottom: 0.25rem;
            }
            .maturity-level.active .maturity-title { color: var(--text); }
            .maturity-desc {
                font-size: 0.72rem;
                color: var(--muted);
                line-height: 1.4;
            }
            .maturity-level.active .maturity-desc { color: var(--dim); }

            /* в”Җв”Җв”Җ QUOTE в”Җв”Җв”Җ */
            .pullquote {
                border-left: 3px solid var(--amber);
                padding: 1.5rem 2rem;
                margin: 3rem 0;
                background: var(--surface);
                border-radius: 0 8px 8px 0;
            }
            .pullquote p {
                font-family: var(--serif);
                font-size: clamp(1.1rem, 2vw, 1.4rem);
                font-style: italic;
                color: var(--text);
                line-height: 1.6;
            }
            .pullquote .attr {
                font-family: var(--mono);
                font-size: 0.7rem;
                color: var(--dim);
                margin-top: 0.75rem;
                font-style: normal;
            }

            /* в”Җв”Җв”Җ FOOTER в”Җв”Җв”Җ */
            footer {
                border-top: 1px solid var(--border);
                padding: 3rem 0;
                position: relative;
                z-index: 1;
            }
            .footer-inner {
                display: flex;
                justify-content: space-between;
                align-items: center;
                flex-wrap: wrap;
                gap: 1rem;
            }
            .footer-brand {
                font-family: var(--serif);
                font-size: 0.85rem;
                font-weight: 600;
                letter-spacing: 0.1em;
                text-transform: uppercase;
                color: var(--dim);
            }
            .footer-brand .rune { color: var(--rune); margin-right: 0.3rem; }
            .footer-links {
                display: flex;
                gap: 1.5rem;
                list-style: none;
            }
            .footer-links a {
                font-family: var(--mono);
                font-size: 0.7rem;
                letter-spacing: 0.06em;
                color: var(--muted);
                transition: color 0.2s;
            }
            .footer-links a:hover { color: var(--amber); }
            .footer-copy {
                width: 100%;
                text-align: center;
                font-size: 0.75rem;
                color: var(--muted);
                margin-top: 1.5rem;
                padding-top: 1.5rem;
                border-top: 1px solid var(--border);
            }
            .footer-runes {
                font-size: 1rem;
                letter-spacing: 0.5em;
                color: var(--rune);
                opacity: 0.3;
                margin-top: 0.75rem;
            }

            /* Section dividers */
            .section-border { border-top: 1px solid var(--border); }

            /* в”Җв”Җв”Җ B2B PATTERN в”Җв”Җв”Җ */
            .b2b-visual {
                background: var(--surface);
                border: 1px solid var(--border);
                border-radius: 10px;
                padding: 2rem;
                margin: 2.5rem 0;
                text-align: center;
            }
            .b2b-visual pre {
                font-family: var(--mono);
                font-size: 0.72rem;
                line-height: 1.8;
                color: var(--dim);
                display: inline-block;
                text-align: left;
            }
            .b2b-visual .your-fort { color: var(--amber); }
            .b2b-visual .partner-fort { color: var(--muted); }
            .b2b-visual .bridge { color: var(--stone); }
            .b2b-visual .token { color: var(--rune); }
        </style>
    </head>

    <body>
        <!-- Ambient glows -->
        <div class="glow glow-1"></div>
        <div class="glow glow-2"></div>

        <!-- Navigation -->
        <nav>
            <div class="nav-inner">
                <a href="#" class="nav-brand"><span class="rune">бҡІ</span> RuneFort</a>
                <ul class="nav-links">
                    <li><a href="#vision">Vision</a></li>
                    <li><a href="#zoom">Zoom</a></li>
                    <li><a href="#dark-factory">Dark Factory</a></li>
                    <li><a href="#overlays">Overlays</a></li>
                    <li><a href="#ecosystem">Ecosystem</a></li>
                    <li><a href="https://github.com/c-u-l8er/runefort" target="_blank" rel="noopener">GitHub</a></li>
                </ul>
            </div>
        </nav>

        <!-- Hero -->
        <header class="hero container">
            <div class="hero-badge">Part of the [&] Protocol ecosystem</div>
            <h1>Walk through your<br /><em>autonomous workflows</em></h1>
            <p class="subline">
                Dark factories run with the lights off. RuneFort turns them back on &mdash;
                not with dashboards, but with a place you can walk through.
            </p>
            <div class="cta-row">
                <a href="#vision" class="btn btn-primary">Explore the Fort</a>
                <a href="https://github.com/c-u-l8er/runefort" class="btn btn-secondary" target="_blank" rel="noopener">View Source</a>
            </div>
            <div class="rune-sequence">бҡІ бҡЁ бҡ  бӣғ бӣһ</div>
        </header>

        <!-- Vision -->
        <section id="vision" class="section-border">
            <div class="container">
                <span class="section-label">Vision</span>
                <h2>Every loop is <em>a building</em></h2>
                <p class="lead">
                    RuneFort renders any PULSE-declared closed loop as a navigable fort &mdash; a blueprint-style
                    floor plan where rooms are cognitive domains, corridors are data flows, walls are policies,
                    and the hidden rune machinery inside the walls is the actual operational code.
                </p>

                <div class="pillar-grid">
                    <div class="pillar">
                        <div class="pillar-icon">бҡІ</div>
                        <h3>[&] Protocol</h3>
                        <p>
                            Structural composition. Defines what capabilities a fort contains.
                            The construction material &mdash; stones, doors, and mechanisms that forts are built from.
                        </p>
                    </div>
                    <div class="pillar">
                        <div class="pillar-icon">бӣҠ</div>
                        <h3>PULSE</h3>
                        <p>
                            Temporal declaration. Defines the fort's heartbeat, phases, and cadence.
                            The clocktower mechanism beating inside every fort.
                        </p>
                    </div>
                    <div class="pillar">
                        <div class="pillar-icon">бӣү</div>
                        <h3>PRISM</h3>
                        <p>
                            Diagnostic measurement. Measures the fort's health from watchtowers.
                            Nine continual learning dimensions, scored and visualized.
                        </p>
                    </div>
                </div>

                <div class="pullquote">
                    <p>The fort is what you understand. The runes are what you inspect.</p>
                    <div class="attr">&mdash; The Minecraft Rule: one primitive composes into any cognitive architecture</div>
                </div>
            </div>
        </section>

        <!-- Zoom Levels -->
        <section id="zoom" class="section-border">
            <div class="container">
                <span class="section-label">Semantic Zoom</span>
                <h2>Five levels of <em>resolution</em></h2>
                <p class="lead">
                    The same tile grid renders differently at each level. Zooming in reveals more;
                    zooming out collapses detail into summary. No special-case rendering &mdash; one primitive, infinite depth.
                </p>

                <div class="zoom-grid" id="zoom-selector">
                    <div class="zoom-card active" data-level="0" onclick="selectZoom(0)">
                        <div class="zoom-level">L0</div>
                        <div class="zoom-name">District</div>
                        <div class="zoom-desc">Multiple forts on a shared landscape. The full ecosystem at a glance.</div>
                    </div>
                    <div class="zoom-card" data-level="1" onclick="selectZoom(1)">
                        <div class="zoom-level">L1</div>
                        <div class="zoom-name">Campus</div>
                        <div class="zoom-desc">Single fort. All wings and zones visible. Room labels from phases.</div>
                    </div>
                    <div class="zoom-card" data-level="2" onclick="selectZoom(2)">
                        <div class="zoom-level">L2</div>
                        <div class="zoom-name">Wing</div>
                        <div class="zoom-desc">Rooms within a zone. Connections between them. Node clusters and edge topology.</div>
                    </div>
                    <div class="zoom-card" data-level="3" onclick="selectZoom(3)">
                        <div class="zoom-level">L3</div>
                        <div class="zoom-name">Room</div>
                        <div class="zoom-desc">Individual nodes, edges, confidence values. The data breathing inside.</div>
                    </div>
                    <div class="zoom-card" data-level="4" onclick="selectZoom(4)">
                        <div class="zoom-level">L4</div>
                        <div class="zoom-name">Rune</div>
                        <div class="zoom-desc">Single operation. The dark code inside a wall. Causal provenance, config.</div>
                    </div>
                </div>

                <!-- Interactive zoom viewer вҖ” xterm blueprint -->
                <div class="zoom-viewer">
                    <div class="zoom-viewer-header">
                        <span class="zoom-viewer-title" id="zoom-viewer-title">L0 вҖ” District View</span>
                        <span class="zoom-viewer-lang" id="zoom-viewer-lang">blueprint</span>
                    </div>
                    <div class="zoom-viewer-body">
                        <div id="rot-container"></div>
                    </div>
                </div>

                <!-- Data panel вҖ” Prism-highlighted JSON for each level -->
                <div class="zoom-data-panel">
                    <div class="zoom-data-header">
                        <span class="zoom-data-title" id="zoom-data-title">District Manifest</span>
                        <span class="zoom-data-lang">json</span>
                    </div>

                        <!-- L0: District вҖ” multi-fort layout (JSON) -->
                        <pre class="zoom-code active" id="zoom-code-0"><code class="language-json">{
  "district": "runefort_ecosystem",
  "forts": [
    { "id": "graphonomous",  "loop": "graphonomous.memory_loop",      "schema": "(sqlite)" },
    { "id": "webhost",       "loop": "webhost.deploy_invoke",         "schema": "webhost.*" },
    { "id": "bendscript",    "loop": "bendscript.knowledge_edit",     "schema": "kag.*" },
    { "id": "agentromatic",  "loop": "agentromatic.deliberation",     "schema": "orchestrate.*" },
    { "id": "delegatic",     "loop": "delegatic.governance",          "schema": "govern.*" },
    { "id": "agentelic",     "loop": "agentelic.build_pipeline",      "schema": "agentelic.*" },
    { "id": "fleetprompt",   "loop": "fleetprompt.marketplace",       "schema": "fleet.*" },
    { "id": "geofleetic",    "loop": "geofleetic.fleet_learning",     "schema": "geo.*" },
    { "id": "ticktickclock", "loop": "ticktickclock.temporal_learning","schema": "temporal.*" }
  ],
  "shared_ground": {
    "schema": "amp.*",
    "tables": ["profiles", "workspaces", "members", "entitlements"]
  },
  "bridges": [
    { "from": "graphonomous",  "to": "prism",       "tokens": ["OutcomeSignal"] },
    { "from": "prism",         "to": "fleetprompt",  "tokens": ["ReputationUpdate"] },
    { "from": "agentromatic",  "to": "prism",        "tokens": ["OutcomeSignal"] },
    { "from": "deliberatic",   "to": "agentromatic", "tokens": ["DeliberationResult"] },
    { "from": "delegatic",     "to": "*",            "tokens": ["PolicyEnforcement"] },
    { "from": "agentelic",     "to": "fleetprompt",  "tokens": ["AgentPublish"] },
    { "from": "agentelic",     "to": "webhost",      "tokens": ["Deploy"] }
  ],
  "bedrock": "opensentience (OS-001 through OS-010)"
}</code></pre>

                        <!-- L1: Campus вҖ” single fort PULSE manifest (JSON) -->
                        <pre class="zoom-code" id="zoom-code-1"><code class="language-json">{
  "pulse_version": "0.1",
  "loop_id": "graphonomous.memory_loop",
  "version": "0.4.0",
  "description": "Continual learning memory loop вҖ” 5 phase machines",
  "phases": [
    {
      "id": "retrieve_context",
      "kind": "retrieve",
      "description": "Fetch relevant nodes, edges, and topology from the knowledge graph",
      "inputs": ["query", "workspace_id"],
      "outputs": ["context_nodes", "topology"],
      "timeout_ms": 5000
    },
    {
      "id": "route_topology",
      "kind": "route",
      "description": "Analyze SCC topology, compute Оә, decide fast-path or deliberation",
      "inputs": ["context_nodes", "topology"],
      "outputs": ["routing_decision", "kappa_value"],
      "timeout_ms": 1000
    },
    {
      "id": "act_mutate",
      "kind": "act",
      "description": "Store nodes, update edges, mutate the knowledge graph",
      "inputs": ["routing_decision", "new_knowledge"],
      "outputs": ["stored_nodes", "updated_edges"],
      "timeout_ms": 3000
    },
    {
      "id": "learn_outcome",
      "kind": "learn",
      "description": "Close the feedback loop вҖ” report outcomes, update confidence",
      "inputs": ["action_result", "outcome_signal"],
      "outputs": ["confidence_deltas", "belief_updates"],
      "timeout_ms": 2000
    },
    {
      "id": "consolidate_idle",
      "kind": "consolidate",
      "description": "Merge similar nodes, prune decay, strengthen co-activated paths",
      "inputs": ["graph_state", "decay_thresholds"],
      "outputs": ["merged_nodes", "pruned_nodes", "promoted_nodes"],
      "timeout_ms": 30000
    }
  ],
  "substrates": {
    "memory": "sqlite://graphonomous.db",
    "policy": "delegatic://workspace/{ws_id}",
    "time": "ticktickclock://workspace/{ws_id}"
  },
  "invariants": {
    "phase_atomicity": true,
    "feedback_immutability": true,
    "kappa_routing": true,
    "outcome_grounding": true
  }
}</code></pre>

                        <!-- L2: Wing вҖ” room detail with node clusters (JSON) -->
                        <pre class="zoom-code" id="zoom-code-2"><code class="language-json">{
  "wing": "retrieve",
  "fort": "graphonomous.memory_loop",
  "rooms": [
    {
      "id": "semantic_memory",
      "tile_count": 42,
      "node_types": ["semantic", "procedural"],
      "avg_confidence": 0.82,
      "activity": 0.91,
      "state": "active",
      "edges_out": ["causal_reasoning", "goal_tracking"]
    },
    {
      "id": "causal_reasoning",
