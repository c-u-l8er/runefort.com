                G+'в”Ӯ                                                                      в”Ӯ',
                G+'в”Ӯ  '+D+'вҡҷ Gate: '+S+'kappa_gate  '+T+'filter: Оә > 0 вҶ’ deliberation  state: '+G+'open'+G+'    в”Ӯ',
                G+'в”Ӯ                                                                      в”Ӯ',
                G+'в””в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”ҳ'
            ];

            // L3 вҖ” Room (semantic_memory detail)
            blueprints[3] = [
                A+'в”Ңв”Җ ROOM: semantic_memory в”Җ Retrieve Wing в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”җ',
                A+'в”Ӯ                                                                       в”Ӯ',
                A+'в”Ӯ  '+T+'node_a7f3c '+D+'(semantic)  conf: '+G+'0.94'+T+'  timescale: '+SE+'slow'+A+'         в”Ӯ',
                A+'в”Ӯ  '+D+'в”Ӯ '+T+'"RuneFort renders PULSE loops as navigable forts"'+A+'            в”Ӯ',
                A+'в”Ӯ  '+D+'в”Ӯ access: 47  decay: 0.002  tags: runefort, viz, pulse'+A+'        в”Ӯ',
                A+'в”Ӯ  '+D+'в”Ӯ'+A+'                                                              в”Ӯ',
                A+'в”Ӯ  '+D+'в”ңв”Җв”Җ'+S+' supports (0.76) '+D+'в”Җв”Җв–¶'+A+'                                        в”Ӯ',
                A+'в”Ӯ  '+D+'в”Ӯ'+A+'                                                              в”Ӯ',
                A+'в”Ӯ  '+T+'node_b2e81 '+D+'(semantic)  conf: '+A+'0.71'+T+'  timescale: '+R+'medium'+A+'       в”Ӯ',
                A+'в”Ӯ  '+D+'в”Ӯ '+T+'"Dark factories need spatial observability for governance"'+A+'   в”Ӯ',
                A+'в”Ӯ  '+D+'в”Ӯ access: 12  decay: 0.010  tags: dark-factory, gov'+A+'            в”Ӯ',
                A+'в”Ӯ  '+D+'в”Ӯ'+A+'                                                              в”Ӯ',
                A+'в”Ӯ  '+D+'в”ңв”Җв”Җ'+S+' related (0.52) '+D+'в”Җв”Җв–¶'+A+'                                         в”Ӯ',
                A+'в”Ӯ  '+D+'в”Ӯ'+A+'                                                              в”Ӯ',
                A+'в”Ӯ  '+T+'node_c9d44 '+D+'(procedural)  conf: '+G+'0.88'+T+'  timescale: '+SE+'slow'+A+'      в”Ӯ',
                A+'в”Ӯ  '+D+'в”Ӯ '+T+'"Parse PULSE manifest вҶ’ generate skeleton вҶ’ populate rooms"'+A+' в”Ӯ',
                A+'в”Ӯ  '+D+'в”Ӯ access: 33  decay: 0.003  tags: pipeline, fort-gen'+A+'           в”Ӯ',
                A+'в”Ӯ  '+D+'в”Ӯ'+A+'                                                              в”Ӯ',
                A+'в”Ӯ  '+D+'в””в”Җв”Җ'+S+' derived_from (0.91) '+D+'в”Җв”Җв–¶ '+T+'node_a7f3c'+A+'                       в”Ӯ',
                A+'в”Ӯ                                                                       в”Ӯ',
                A+'в”Ӯ  '+D+'в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ'+A+'  в”Ӯ',
                A+'в”Ӯ  '+D+'metrics:'+T+'  nodes: 42  avg_conf: '+G+'0.82'+T+'  SCCs: 2  Оә: '+G+'0'+A+'            в”Ӯ',
                A+'в”Ӯ                                                                       в”Ӯ',
                A+'в””в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”ҳ'
            ];

            // L4 вҖ” Rune (single operation)
            blueprints[4] = [
                R+'в”Ңв”Җ RUNE: бҡІ Kaunan в”Җ torch / knowledge в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”җ',
                R+'в”Ӯ                                                                       в”Ӯ',
                R+'в”Ӯ  '+T+'Operation: '+G+'retrieve_context'+R+'                                       в”Ӯ',
                R+'в”Ӯ  '+T+'Machine:   '+S+'retrieve'+R+'                                               в”Ӯ',
                R+'в”Ӯ  '+T+'Phase:     '+S+'retrieve_context '+D+'(kind: retrieve)'+R+'                      в”Ӯ',
                R+'в”Ӯ                                                                       в”Ӯ',
                R+'в”Ӯ  '+D+'в”Җв”Җ invocation в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ'+R+'  в”Ӯ',
                R+'в”Ӯ  '+D+'tool:     '+G+'graphonomous.retrieve'+R+'                                   в”Ӯ',
                R+'в”Ӯ  '+D+'action:   '+S+'context'+R+'                                                 в”Ӯ',
                R+'в”Ӯ  '+D+'query:    '+A+'"dark factory spatial observability governance"'+R+'          в”Ӯ',
                R+'в”Ӯ  '+D+'max:      '+T+'50 nodes  min_conf: 0.3  topology: '+G+'true'+R+'              в”Ӯ',
                R+'в”Ӯ                                                                       в”Ӯ',
                R+'в”Ӯ  '+D+'в”Җв”Җ execution в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ'+R+'  в”Ӯ',
                R+'в”Ӯ  '+D+'duration: '+G+'142ms   '+T+'nodes: 12   edges: 28'+R+'                       в”Ӯ',
                R+'в”Ӯ                                                                       в”Ӯ',
                R+'в”Ӯ  '+D+'в”Җв”Җ topology в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ'+R+'  в”Ӯ',
                R+'в”Ӯ  '+D+'scc_0:    '+G+'[node_a7f3c, node_b2e81]          '+T+'Оә = '+G+'0'+R+'              в”Ӯ',
                R+'в”Ӯ  '+D+'scc_1:    '+AL+'[node_d1f22, node_e3a99, node_f7b11]  '+T+'Оә = '+AL+'1'+R+'     в”Ӯ',
                R+'в”Ӯ  '+D+'routing:  '+AL+'DELIBERATE  '+D+'(Оә=1 in scc_1 вҖ” cyclic belief)'+R+'       в”Ӯ',
                R+'в”Ӯ                                                                       в”Ӯ',
                R+'в”Ӯ  '+D+'в”Җв”Җ causal provenance в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ'+R+'  в”Ӯ',
                R+'в”Ӯ  '+D+'trigger:  '+T+'user_query'+R+'                                              в”Ӯ',
                R+'в”Ӯ  '+D+'trace:    '+D+'tr_2026-04-14_091200_a7f3c'+R+'                             в”Ӯ',
                R+'в”Ӯ  '+D+'child:    '+S+'route_topology'+R+'                                          в”Ӯ',
                R+'в”Ӯ                                                                       в”Ӯ',
                R+'в”Ӯ  '+D+'в”Җв”Җ rune sequence в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ'+R+'  в”Ӯ',
                R+'в”Ӯ  '+R+'  бҡІ  вҶ’  бҡЁ  вҶ’  бҡұ  вҶ’  бҡ '+R+'                                        в”Ӯ',
                R+'в”Ӯ  '+D+'  retrieve вҶ’ route вҶ’ deliberate вҶ’ act'+R+'                           в”Ӯ',
                R+'в”Ӯ                                                                       в”Ӯ',
                R+'в””в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”ҳ'
            ];

            var zoomTitles = [
                'L0 вҖ” District View',
                'L1 вҖ” Campus View',
                'L2 вҖ” Wing View',
                'L3 вҖ” Room View',
                'L4 вҖ” Rune View'
            ];
            var dataTitles = [
                'District Manifest',
                'PULSE Loop Manifest',
                'Wing Topology',
                'Room Node Graph',
                'Operation Trace'
            ];

            var display = null;
            var COLS = 78;

            function initDisplay() {
                var container = document.getElementById('rot-container');
                if (!container || typeof ROT === 'undefined') return;

                display = new ROT.Display({
                    width: COLS,
                    height: 30,
                    fontSize: 14,
                    fontFamily: '"JetBrains Mono", monospace',
                    bg: bg,
                    fg: text,
                    spacing: 1.05,
                    forceSquareRatio: false
                });
                container.appendChild(display.getContainer());
                drawBlueprint(0);
            }

            function drawBlueprint(level) {
                if (!display) return;
                display.clear();
                var lines = blueprints[level];
                for (var y = 0; y < lines.length; y++) {
                    display.drawText(0, y, lines[y], COLS);
                }
            }

            function selectZoom(level) {
                // Update cards
                var cards = document.querySelectorAll('.zoom-card');
                cards.forEach(function(c) { c.classList.remove('active'); });
                cards[level].classList.add('active');

                // Update rot.js blueprint
                drawBlueprint(level);

                // Update Prism code panels
                var codes = document.querySelectorAll('.zoom-code');
                codes.forEach(function(c) { c.classList.remove('active'); });
                document.getElementById('zoom-code-' + level).classList.add('active');

                // Update headers
                document.getElementById('zoom-viewer-title').textContent = zoomTitles[level];
                document.getElementById('zoom-data-title').textContent = dataTitles[level];
            }
            // Make selectZoom available globally
            window.selectZoom = selectZoom;

            // Init
            if (typeof Prism !== 'undefined') Prism.highlightAll();
            if (document.readyState === 'complete') {
                initDisplay();
            } else {
                window.addEventListener('load', initDisplay);
            }
        })();
        </script>
    </body>
</html>
