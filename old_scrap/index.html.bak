      "avg_confidence": 0.78,
      "activity": 0.65,
      "state": "active",
      "edges_out": ["semantic_memory", "causal_reasoning"]
    }
  ],
  "corridors": [
    { "from": "semantic_memory", "to": "causal_reasoning", "weight": 0.88 },
    { "from": "episodic_buffer", "to": "semantic_memory", "weight": 0.41 },
    { "from": "goal_tracking", "to": "causal_reasoning", "weight": 0.72 }
  ],
  "gates": [
    { "id": "kappa_gate", "filter": "Оә > 0 вҶ’ deliberation_corridor", "state": "open" }
  ]
}</code></pre>

                        <!-- L3: Room вҖ” individual nodes and edges (JSON) -->
                        <pre class="zoom-code" id="zoom-code-3"><code class="language-json">{
